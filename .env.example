# BTC Scalp Dashboard v2 — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Exchange: "binance.com" for production (most users), "binance.us" for US-based users
EXCHANGE=binance.com

# Trading pair (lowercase)
SYMBOL=btcusdt

# Server host and port
HOST=0.0.0.0
PORT=5000

# Transaction cost settings (decimal, not percentage)
# Fee = 0.001 means 0.1% taker fee (Binance default)
# Slippage = 0.0005 means 0.05% estimated slippage
FEE_RATE=0.001
SLIPPAGE_RATE=0.0005
